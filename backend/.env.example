# Backend Environment Variables
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (AWS RDS PostgreSQL)
# Use sslmode=verify-full for strong TLS verification when connecting to RDS.
DATABASE_URL=postgresql://username:password@localhost:5432/shoesstore?sslmode=verify-full

# DB pool tuning (Drizzle/postgres-js)
DB_POOL_MAX=8
DB_POOL_IDLE_TIMEOUT_SECONDS=30
DB_POOL_CONNECT_TIMEOUT_SECONDS=30

# Session + shared rate-limit pool tuning (node-postgres)
SESSION_DB_POOL_MAX=4
SESSION_DB_POOL_IDLE_TIMEOUT_MS=30000
SESSION_DB_POOL_CONNECT_TIMEOUT_MS=5000

# Shared rate limiting (backed by PostgreSQL)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
RATE_LIMIT_CLEANUP_INTERVAL_MS=600000
RATE_LIMIT_TABLE=rate_limit_hits

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long

# Session
SESSION_SECRET=your_super_secret_session_key_min_32_characters_long

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=shoes-store-images

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (Development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@shoesstore.com
SMTP_CONNECTION_TIMEOUT=10000
SMTP_GREETING_TIMEOUT=10000
SMTP_SOCKET_TIMEOUT=15000
SMTP_REQUIRE_TLS=false

# AWS SNS (Production)
AWS_REGION=us-east-1
USE_AWS_SNS=false
AWS_SNS_TOPIC_ARN=
